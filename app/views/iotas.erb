<!DOCTYPE html>
<html lang="en">
<%= erb :_head %>
<body>
    <%= erb :_header, locals: { page: @page } %>
    <div id="page">
        <%= erb :_sidebar %>
        <div id="main">
            <%= erb :_breadcrumb %>
            <%= erb :_toolbar %>
            <%= erb :_iotas, locals: { title: @title, iotas: defined?(@iotas) ? @iotas : get_iotas } %>
            <%= erb :_pagination %>
        </div>
    </div>
    <%= erb :_footer %>
</body>
</html>