<!DOCTYPE html>
<html lang="en">
<%= erb :_head %>
<body>
    <%= erb :_header %>
    <div id="page">
        <%= erb :_sidebar, locals: { active_collection_id: @collection.id } %>
        <div id="main">
            <%= erb :_breadcrumb %>
            <%= erb :_toolbar %>
            <%= erb :_iotas, locals: { title: @collection.title, iotas: @collection.iotas } %>
            <%= erb :_pagination %>
        </div>
    </div>
    <%= erb :_footer %>
</body>
</html>