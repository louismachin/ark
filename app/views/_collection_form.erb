<div class="collection-header">
    <h2>Add Collection</h2>
    <span class="meta">Archive a new collection</span>
</div>

<form class="entry-form" action="/collections/new" method="post" enctype="multipart/form-data">

    <div class="form-section">

        <div class="form-row">
            <label for="collection_title">Title</label>
            <input type="text" id="collection_title" name="collection[title]" class="field-input" placeholder="Collection title">
        </div>

        <div class="form-row">
            <label for="collection_description">Description</label>
            <textarea id="collection_description" name="collection[description]" class="field-input" rows="4" placeholder="Short description of this collection&hellip;"></textarea>
        </div>

        <div class="form-row">
            <label for="collection_tags">Tags</label>
            <input type="text" id="collection_tags" name="collection[tags]" class="field-input" placeholder="comma, separated, tags">
        </div>

        <div class="form-row">
            <label>Metadata</label>
            <div id="metadata-rows" class="metadata-rows">
                <div class="metadata-row">
                    <input type="text" name="collection[metadata_keys][]" class="field-input" placeholder="key">
                    <span class="metadata-eq">=</span>
                    <input type="text" name="collection[metadata_values][]" class="field-input" placeholder="value">
                    <a href="#" class="btn metadata-remove" onclick="return removeMetadataRow(this)">&times;</a>
                </div>
            </div>
            <a href="#" class="btn metadata-add" onclick="return addMetadataRow()">+ add field</a>
        </div>

    </div>

    <div class="form-actions">
        <button type="submit" class="btn primary">Add Collection</button>
        <a href="/collections" class="btn">Cancel</a>
        <span class="form-hint">* required fields</span>
    </div>

</form>

<script>
function addMetadataRow() {
    var container = document.getElementById('metadata-rows');
    var row = container.firstElementChild.cloneNode(true);
    row.querySelectorAll('input').forEach(function (input) { input.value = ''; });
    container.appendChild(row);
    return false;
}

function removeMetadataRow(link) {
    var container = document.getElementById('metadata-rows');
    if (container.children.length > 1) {
        link.closest('.metadata-row').remove();
    }
    return false;
}
</script>
