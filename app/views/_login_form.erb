<div class="collection-header">
    <h2>Login</h2>
    <span class="meta">To edit entries you must login</span>
</div>

<form class="entry-form" action="/login" method="post" enctype="multipart/form-data">

    <div class="form-section">

        <div class="form-row">
            <label for="login_username">Username</label>
            <input type="text" id="login_username" name="login[username]" class="field-input" placeholder="Username">
        </div>

        <div class="form-row">
            <label for="login_password">Password</label>
            <input type="password" id="login_password" name="login[password]" class="field-input" placeholder="Password">
        </div>

    </div>

    <div class="form-actions">
        <button type="submit" class="btn primary">Login</button>
        <a href="/" class="btn">Cancel</a>
    </div>

</form>